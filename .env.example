# Bounce — Example environment variables
# Copy this file to .env and adjust for your setup

# Server port
BOUNCE_PORT=3001

# Data directory for SQLite database
BOUNCE_DATA_DIR=/data

# Rate limit: requests per minute per IP (default: 100)
# BOUNCE_RATE_LIMIT=500

# Domains that bypass rate limiting (comma-separated)
# BOUNCE_TRUSTED_ORIGINS=example.com,myothersite.pt

# API key for server-to-server rate limit bypass
# DRIBLY_KEY=your-secret-key-here

# Enable HTTPS with LetsEncrypt (requires public domain)
# BOUNCE_TLS_DOMAIN=api.example.com
# BOUNCE_TLS_CACHE=/data/autocert

# Silence request logs
# BOUNCE_QUIET=true

# Terminal dashboard mode (no web server)
# BOUNCE_TUI=true

# CORS origin (default: *)
# BOUNCE_CORS_ORIGIN=https://example.com

# Log level: warn (default) or debug
# BOUNCE_LOG_LEVEL=debug
